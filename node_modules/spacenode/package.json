{
  "name": "spacenode",
  "version": "1.1.0",
  "description": "SpaceNode - Node.js microservice framework. Auto-discovery modules, SSR, REST API, static-site, pipeline middleware, DI container (singleton/transient/scoped), event bus, guards, WebSocket, dto and zero dependencies - all in one box.",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "scripts": {
    "test": "node --test test/**/*.test.js",
    "prepare": "npm test",
    "prepack": "npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "spacenode",
    "framework",
    "microservices",
    "REST API",
    "SSR",
    "WebSocket",
    "templates",
    "guards",
    "http",
    "server",
    "rest",
    "api",
    "modular",
    "auto-discovery",
    "pipeline",
    "dependency-injection",
    "event-bus",
    "zero-dependencies"
  ],
  "license": "MIT",
  "author": "Roman Kulichenko",
  "repository": {
    "type": "git",
    "url": "https://github.com/1romankulichenko/SpaceNode"
  },
  "homepage": "https://spacenode.org/",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "lib/**",
    "docs/**",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "package.json"
  ]
}
